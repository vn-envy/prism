# PRISM Environment Configuration
# Copy to .env and fill in your keys

# === Frontier Judge APIs (Gauge R&R panel) ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# === Candidate Model Providers ===
TOGETHER_API_KEY=...
DEEPSEEK_API_KEY=...
SARVAM_API_KEY=...
COHERE_API_KEY=...

# === Observability (Langfuse) ===
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...
LANGFUSE_HOST=https://cloud.langfuse.com

# === Database ===
DATABASE_URL=postgresql+asyncpg://prism:prism@localhost:5432/prism

# === Configuration ===
MAX_WALL_CLOCK_SECONDS=90
MAX_COST_PER_INTENT_USD=0.50
DEFAULT_LSL=70
DEFAULT_N_TRIALS=5
DEFAULT_N_JUDGES=3
